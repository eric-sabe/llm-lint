# Copy this file to .env (which is gitignored) and fill in keys for the providers you
# want to sample. A model whose key is unset is skipped, so you can set just one to start.
# Used by: node --env-file-if-exists=.env generate-samples.mjs   (npm run generate)

# API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Model ids (the versions to sample). Set these to the current release for each provider
# and just bump them here when a new model ships - no need to touch models.json or code.
# If a *_MODEL var is unset, generate-samples falls back to the default in models.json.
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-5
GEMINI_MODEL=gemini-2.5-pro
XAI_MODEL=grok-4
