# Copy this file to .env (which is gitignored) and fill in keys for the providers you
# want to sample. A model whose key is unset is skipped, so you can set just one to start.
# Used by: node --env-file-if-exists=.env generate-samples.mjs   (npm run generate)

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
